# backend/.env.example
# Copier en .env et remplir les valeurs

# Base de données
DB_HOST=localhost
DB_NAME=mercato_nova
DB_USER=root
DB_PASSWORD=

# Serveur
APP_URL=http://localhost:8000
APP_ENV=development
APP_DEBUG=true

# Sécurité
SESSION_NAME=MERCATO_NOVA_SESSION
SESSION_TIMEOUT=3600
SESSION_PATH=/

# Upload
UPLOAD_DIR=public/uploads
MAX_FILE_SIZE=5242880

# Email (pour future utilisation)
MAIL_FROM=no-reply@mercato-nova.fr
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
